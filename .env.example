# Kopieren nach .env und anpassen!
#   cp .env.example .env && nano .env
# Geheimen Key generieren:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"

DJANGO_SECRET_KEY=BITTE-EINEN-LANGEN-ZUFALLSSTRING-EINSETZEN
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=tickets.deinedomain.de
CSRF_TRUSTED_ORIGINS=https://tickets.deinedomain.de

# Bootstrap-Admin (wird nur angelegt, wenn noch kein Admin existiert)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# Komplett deaktivieren mit:
# BOOTSTRAP_ADMIN_DISABLED=1

# E-Mail (optional; ohne EMAIL_HOST geht alles in die Konsole)
# EMAIL_HOST=smtp.deinprovider.de
# EMAIL_PORT=587
# EMAIL_HOST_USER=ticketsystem@deinedomain.de
# EMAIL_HOST_PASSWORD=geheim
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=ticketsystem@deinedomain.de
