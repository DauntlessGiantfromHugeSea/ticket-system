# .env-Vorlage für lokale Entwicklung (außerhalb von Docker).
# Im Docker-Setup werden die Variablen direkt im docker-compose.yml gesetzt
# (siehe deploy/docker-compose.snippet.yml).

DJANGO_SECRET_KEY=BITTE-EINEN-LANGEN-ZUFALLSSTRING-EINSETZEN
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=

# Persistenter Datenordner (DB + Media). Auf dem VPS = /data im Container.
# DATA_DIR=/data

# Bootstrap-Admin (wird nur angelegt, wenn noch kein Admin existiert)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin
BOOTSTRAP_ADMIN_EMAIL=admin@fb-eng.de
# BOOTSTRAP_ADMIN_DISABLED=1

# E-Mail (optional)
# EMAIL_HOST=smtp.deinprovider.de
# EMAIL_PORT=587
# EMAIL_HOST_USER=ticketsystem@fb-eng.de
# EMAIL_HOST_PASSWORD=geheim
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=ticketsystem@fb-eng.de
